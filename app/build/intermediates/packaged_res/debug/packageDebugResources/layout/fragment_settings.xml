<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/brand_blue"
            app:title="@string/settings_title"
            app:titleTextColor="@color/header_text"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/header_text" />

        <!-- Уведомления -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_notifications"
            android:textSize="12sp"
            android:textColor="@color/brand_blue"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:letterSpacing="0.08" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/background_card"
            android:elevation="1dp">

            <!-- Уведомления о сообщениях -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView android:layout_width="32dp" android:layout_height="32dp"
                    android:text="💬" android:textSize="20sp" android:gravity="center" />
                <TextView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_notif_messages"
                    android:textSize="15sp" android:textColor="@color/text_primary"
                    android:layout_marginStart="12dp" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchNotifMessages"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginStart="60dp" android:background="@color/border_color" />

            <!-- Уведомления о новых объявлениях -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView android:layout_width="32dp" android:layout_height="32dp"
                    android:text="🔔" android:textSize="20sp" android:gravity="center" />
                <TextView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_notif_new_ads"
                    android:textSize="15sp" android:textColor="@color/text_primary"
                    android:layout_marginStart="12dp" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchNotifNewAds"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="false" />
            </LinearLayout>

        </LinearLayout>

        <!-- Конфиденциальность -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_privacy"
            android:textSize="12sp"
            android:textColor="@color/brand_blue"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:letterSpacing="0.08" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/background_card"
            android:elevation="1dp">

            <!-- Показывать номер телефона -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView android:layout_width="32dp" android:layout_height="32dp"
                    android:text="📞" android:textSize="20sp" android:gravity="center" />
                <LinearLayout
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:orientation="vertical"
                    android:layout_marginStart="12dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/settings_show_phone"
                        android:textSize="15sp" android:textColor="@color/text_primary" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/settings_show_phone_hint"
                        android:textSize="12sp" android:textColor="@color/text_tertiary" />
                </LinearLayout>
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchShowPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginStart="60dp" android:background="@color/border_color" />

            <!-- Показывать онлайн статус -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView android:layout_width="32dp" android:layout_height="32dp"
                    android:text="👁" android:textSize="20sp" android:gravity="center" />
                <TextView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_show_online"
                    android:textSize="15sp" android:textColor="@color/text_primary"
                    android:layout_marginStart="12dp" />
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchShowOnline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />
            </LinearLayout>

        </LinearLayout>

        <!-- О приложении -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_section_about"
            android:textSize="12sp"
            android:textColor="@color/brand_blue"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="16dp"
            android:paddingBottom="8dp"
            android:letterSpacing="0.08" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/background_card"
            android:elevation="1dp"
            android:layout_marginBottom="24dp">

            <!-- Версия -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <TextView android:layout_width="32dp" android:layout_height="32dp"
                    android:text="ℹ️" android:textSize="20sp" android:gravity="center" />
                <TextView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_version"
                    android:textSize="15sp" android:textColor="@color/text_primary"
                    android:layout_marginStart="12dp" />
                <TextView
                    android:id="@+id/tvVersion"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1.0.0"
                    android:textSize="14sp"
                    android:textColor="@color/text_tertiary" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginStart="60dp" android:background="@color/border_color" />

            <!-- Очистить кэш -->
            <LinearLayout
                android:id="@+id/itemClearCache"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">
                <TextView android:layout_width="32dp" android:layout_height="32dp"
                    android:text="🗑️" android:textSize="20sp" android:gravity="center" />
                <TextView
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/settings_clear_cache"
                    android:textSize="15sp" android:textColor="@color/text_primary"
                    android:layout_marginStart="12dp" />
                <ImageView android:layout_width="16dp" android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_right" app:tint="@color/text_tertiary" />
            </LinearLayout>

        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="24dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
