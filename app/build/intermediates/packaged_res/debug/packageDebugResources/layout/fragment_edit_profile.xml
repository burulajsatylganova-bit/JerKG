<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#1A6EFF"
            app:title="Редактировать профиль"
            app:titleTextColor="#FFFFFF"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="#FFFFFF" />

        <!-- Аватар -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="32dp"
            android:paddingBottom="24dp"
            android:background="@color/background_card">

            <FrameLayout
                android:layout_width="96dp"
                android:layout_height="96dp">

                <!-- Круглый аватар с инициалами -->
                <TextView
                    android:id="@+id/tvAvatarLetter"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:text="А"
                    android:textSize="36sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:gravity="center"
                    android:background="#1A6EFF" />

                <!-- Кнопка смены фото -->
                <TextView
                    android:id="@+id/btnChangePhoto"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="bottom|end"
                    android:text="📷"
                    android:textSize="14sp"
                    android:gravity="center"
                    android:background="@color/background_card"
                    android:elevation="2dp" />

            </FrameLayout>

            <TextView
                android:id="@+id/tvPhoneLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+996 — — —"
                android:textSize="14sp"
                android:textColor="@color/text_tertiary"
                android:layout_marginTop="12dp" />

        </LinearLayout>

        <!-- Форма -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/background_card"
            android:layout_marginTop="12dp"
            android:padding="16dp">

            <!-- Имя -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/edit_profile_name_label"
                android:textSize="13sp"
                android:textColor="@color/text_tertiary"
                android:layout_marginBottom="6dp" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                app:boxCornerRadiusTopStart="10dp"
                app:boxCornerRadiusTopEnd="10dp"
                app:boxCornerRadiusBottomStart="10dp"
                app:boxCornerRadiusBottomEnd="10dp"
                app:boxStrokeColor="#1A6EFF"
                android:layout_marginBottom="20dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/edit_profile_name_hint"
                    android:inputType="textPersonName|textCapWords"
                    android:textSize="15sp"
                    android:padding="14dp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Регион -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/edit_profile_region_label"
                android:textSize="13sp"
                android:textColor="@color/text_tertiary"
                android:layout_marginBottom="6dp" />

            <Spinner
                android:id="@+id/spinnerRegion"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_spinner"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:textSize="15sp"
                android:layout_marginBottom="20dp" />

        </LinearLayout>

        <!-- Кнопка сохранить -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/edit_profile_save"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            app:backgroundTint="#1A6EFF"
            app:cornerRadius="12dp"
            android:layout_margin="16dp" />

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            android:indeterminateTint="#1A6EFF"
            android:layout_marginBottom="16dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
