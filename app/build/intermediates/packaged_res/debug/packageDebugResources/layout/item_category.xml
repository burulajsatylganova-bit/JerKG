<?xml version="1.0" encoding="utf-8"?>
<!-- Файл: app/src/main/res/layout/item_category.xml -->
<!-- Элемент горизонтального списка категорий -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="4dp"
    android:layout_marginEnd="8dp">

    <!-- Иконка категории -->
    <View
        android:id="@+id/vCategoryBg"
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/bg_category"
        android:backgroundTint="#F0F4FF" />

    <!-- Иконка поверх фона -->
    <!-- (в реальном проекте это FrameLayout, здесь упрощено) -->
    <ImageView
        android:id="@+id/ivCategoryIcon"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginTop="-40dp"
        android:layout_marginBottom="12dp"
        android:src="@drawable/ic_cat_electronics"
        android:padding="2dp" />

    <TextView
        android:id="@+id/tvCategoryName"
        android:layout_width="64dp"
        android:layout_height="wrap_content"
        android:text="Категория"
        android:textSize="10sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:maxLines="2"
        android:ellipsize="end"
        android:lineSpacingMultiplier="1.1" />

</LinearLayout>
