<?xml version="1.0" encoding="utf-8"?>
<!-- Файл: app/src/main/res/values/themes.xml -->
<resources>

    <!-- Основная тема -->
    <style name="Theme.JerKG" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/brand_blue</item>
        <item name="colorPrimaryVariant">@color/brand_blue_dark</item>
        <item name="colorSecondary">@color/brand_emerald</item>
        <item name="android:windowBackground">@color/background_primary</item>
        <item name="android:statusBarColor">@color/brand_blue</item>
    </style>

    <!-- Тема для Splash экрана — без статус бара -->
    <style name="Theme.JerKG.Splash" parent="Theme.JerKG">
        <item name="android:windowFullscreen">false</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowTranslucentStatus">true</item>
    </style>

</resources>
