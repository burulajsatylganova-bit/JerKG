<?xml version="1.0" encoding="utf-8"?>
<!-- Файл: app/src/main/res/layout/activity_login.xml -->
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Логотип и заголовок -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="40dp">

            <!-- Иконка логотипа -->
            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_logo"
                android:background="@drawable/bg_logo"
                android:padding="16dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ЖЕР КГ"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/brand_dark"
                android:letterSpacing="-0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Маркетплейс Кыргызстана"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- === ШАГ 1: Ввод номера телефона === -->
        <LinearLayout
            android:id="@+id/layoutStep1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Введите номер телефона"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/brand_dark"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Мы отправим вам SMS с кодом подтверждения"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="24dp" />

            <!-- Поле ввода номера телефона -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="+996 700 123 456"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="16dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/brand_blue">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:textSize="16sp"
                    android:padding="14dp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Кнопка "Получить код" -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSendCode"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Получить код"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/brand_blue"
                app:cornerRadius="12dp" />

        </LinearLayout>

        <!-- === ШАГ 2: Ввод SMS кода === -->
        <LinearLayout
            android:id="@+id/layoutStep2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Введите код из SMS"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/brand_dark"
                android:layout_marginBottom="8dp" />

            <!-- Подсказка с номером -->
            <TextView
                android:id="@+id/tvPhoneHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Код отправлен на +996..."
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="24dp" />

            <!-- Поле ввода кода -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="- - - - - -"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_marginBottom="16dp"
                app:boxCornerRadiusTopStart="12dp"
                app:boxCornerRadiusTopEnd="12dp"
                app:boxCornerRadiusBottomStart="12dp"
                app:boxCornerRadiusBottomEnd="12dp"
                app:boxStrokeColor="@color/brand_blue">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:maxLength="6"
                    android:textSize="24sp"
                    android:gravity="center"
                    android:letterSpacing="0.3"
                    android:padding="14dp" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Кнопка "Войти" -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnVerify"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Войти"
                android:textSize="16sp"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/brand_blue"
                app:cornerRadius="12dp"
                android:layout_marginBottom="12dp" />

            <!-- Изменить номер -->
            <TextView
                android:id="@+id/tvChangePhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Изменить номер телефона"
                android:textSize="14sp"
                android:textColor="@color/brand_blue"
                android:gravity="center"
                android:padding="8dp" />

        </LinearLayout>

        <!-- Прогресс индикатор -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            android:indeterminateTint="@color/brand_blue" />

    </LinearLayout>
</ScrollView>
