<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F9FC">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Шапка: градиентный фон с аватаром и именем -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="130dp"
            android:background="#1A6EFF"
            android:padding="20dp">

            <!-- Аватар -->
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivAvatar"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:src="@drawable/ic_profile"
                android:layout_centerVertical="true"
                android:layout_alignParentStart="true"
                app:civ_border_width="2dp"
                app:civ_border_color="#FFFFFF" />

            <!-- Имя и телефон -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_centerVertical="true"
                android:layout_toEndOf="@id/ivAvatar"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Пользователь"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:id="@+id/tvPhone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+996 — — —"
                    android:textSize="13sp"
                    android:textColor="#CCE0FF"
                    android:layout_marginTop="3dp" />

            </LinearLayout>

            <!-- Кнопка редактирования профиля -->
            <ImageView
                android:id="@+id/btnEditProfile"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_edit"
                android:background="#33FFFFFF"
                android:padding="8dp"
                android:layout_margin="4dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless" />

        </RelativeLayout>

        <!-- Меню-карточка -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:layout_margin="16dp"
            android:elevation="2dp"
            app:layout_constraintTop_toTopOf="parent">

            <!-- Мои объявления -->
            <LinearLayout
                android:id="@+id/itemMyAds"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="📋"
                    android:textSize="20sp"
                    android:gravity="center" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Мои объявления"
                        android:textSize="15sp"
                        android:textColor="#0A1628"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvMyAdsCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0 активных"
                        android:textSize="12sp"
                        android:textColor="#8A94A6" />

                </LinearLayout>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#8A94A6" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginStart="60dp" android:background="#F0F0F0" />

            <!-- Уведомления -->
            <LinearLayout
                android:id="@+id/itemNotifications"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="🔔"
                    android:textSize="20sp"
                    android:gravity="center" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Уведомления"
                        android:textSize="15sp"
                        android:textColor="#0A1628"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvNotifCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="нет новых"
                        android:textSize="12sp"
                        android:textColor="#8A94A6" />

                </LinearLayout>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#8A94A6" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginStart="60dp" android:background="#F0F0F0" />

            <!-- Мои избранные -->
            <LinearLayout
                android:id="@+id/itemFavorites"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="❤️"
                    android:textSize="20sp"
                    android:gravity="center" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Мои избранные"
                        android:textSize="15sp"
                        android:textColor="#0A1628"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvFavCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="12sp"
                        android:textColor="#8A94A6" />

                </LinearLayout>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#8A94A6" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginStart="60dp" android:background="#F0F0F0" />

            <!-- Язык -->
            <LinearLayout
                android:id="@+id/itemLanguage"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="🌐"
                    android:textSize="20sp"
                    android:gravity="center" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="12dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Язык"
                        android:textSize="15sp"
                        android:textColor="#0A1628"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvCurrentLang"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Русский"
                        android:textSize="12sp"
                        android:textColor="#8A94A6" />

                </LinearLayout>

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#8A94A6" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginStart="60dp" android:background="#F0F0F0" />

            <!-- Тёмная тема -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="🌙"
                    android:textSize="20sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Тёмная тема"
                    android:textSize="15sp"
                    android:textColor="#0A1628"
                    android:textStyle="bold"
                    android:layout_marginStart="12dp" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/switchDarkTheme"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginStart="60dp" android:background="#F0F0F0" />

            <!-- Настройки -->
            <LinearLayout
                android:id="@+id/itemSettings"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="⚙️"
                    android:textSize="20sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Настройки"
                    android:textSize="15sp"
                    android:textColor="#0A1628"
                    android:textStyle="bold"
                    android:layout_marginStart="12dp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#8A94A6" />

            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:layout_marginStart="60dp" android:background="#F0F0F0" />

            <!-- Поддержка -->
            <LinearLayout
                android:id="@+id/itemSupport"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:text="❓"
                    android:textSize="20sp"
                    android:gravity="center" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Поддержка"
                    android:textSize="15sp"
                    android:textColor="#0A1628"
                    android:textStyle="bold"
                    android:layout_marginStart="12dp" />

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_arrow_right"
                    app:tint="#8A94A6" />

            </LinearLayout>

        </LinearLayout>

        <!-- Кнопка выхода -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Выйти из аккаунта"
            android:textSize="15sp"
            android:textColor="#FF3B30"
            app:backgroundTint="#FFF0EE"
            app:strokeColor="#FF3B30"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="24dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>