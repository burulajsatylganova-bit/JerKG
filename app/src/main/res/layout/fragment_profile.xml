<?xml version="1.0" encoding="utf-8"?>
<!-- Файл: app/src/main/res/layout/fragment_profile.xml -->
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Шапка профиля -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:background="@color/background_card"
            android:layout_marginBottom="8dp">

            <!-- Аватар -->
            <de.hdodenhof.circleimageview.CircleImageView
                android:id="@+id/ivAvatar"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_profile"
                android:layout_marginBottom="12dp"
                app:civ_border_width="2dp"
                app:civ_border_color="@color/brand_blue" />

            <!-- Номер телефона -->
            <TextView
                android:id="@+id/tvPhone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+996 — — —"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Пользователь ЖЕР КГ"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />

        </LinearLayout>

        <!-- Мои объявления -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/background_card"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvMyAdsCount"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Мои объявления"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:padding="16dp" />

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:visibility="gone"
                android:indeterminateTint="@color/brand_blue" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMyAds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:padding="8dp" />

            <!-- Пустые объявления -->
            <LinearLayout
                android:id="@+id/layoutNoAds"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="У вас пока нет объявлений"
                    android:textSize="14sp"
                    android:textColor="@color/text_tertiary"
                    android:gravity="center" />

            </LinearLayout>

        </LinearLayout>

        <!-- Выход -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Выйти из аккаунта"
            android:textSize="15sp"
            android:textColor="@color/error_red"
            app:backgroundTint="@android:color/transparent"
            app:strokeColor="@color/error_red"
            app:strokeWidth="1dp"
            app:cornerRadius="12dp"
            android:layout_margin="16dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
